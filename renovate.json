{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "automerge": false,
  "packageRules": [
    {
      "description": "Mark major updates for maintainer review",
      "matchUpdateTypes": ["major"],
      "addLabels": ["needs-maintainer-review"]
    }
  ]
}
